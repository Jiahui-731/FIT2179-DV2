    {
      "description": "Beach rays",
      "data": {
        "url": "data/beach_radial.csv",
        "format": {
          "parse": {
            "inner_x": "number",
            "inner_y": "number",
            "dot_x": "number",
            "dot_y": "number",
            "label_x": "number",
            "label_y": "number",
            "avg_enterococci": "number",
            "poor_pct": "number",
            "samples": "number"
          }
        }
      },
      "mark": {
        "type": "rule",
        "strokeWidth": 2.6,
        "strokeCap": "round"
      },
      "encoding": {
        "x": {
          "field": "inner_x",
          "type": "quantitative",
          "scale": {
            "domain": [
              0,
              720
            ]
          },
          "axis": null
        },
        "y": {
          "field": "inner_y",
          "type": "quantitative",
          "scale": {
            "domain": [
              760,
              0
            ]
          },
          "axis": null
        },
        "x2": {
          "field": "dot_x"
        },
        "y2": {
          "field": "dot_y"
        },
        "color": {
          "field": "region",
          "type": "nominal",
          "scale": {
            "domain": [
              "Western Shore",
              "Mornington Peninsula",
              "Eastern Bayside",
              "Inner North"
            ],
            "range": [
              "#3a7ca5",
              "#7ba7c7",
              "#d4a23a",
              "#c73e3e"
            ]
          },
          "legend": {
            "orient": "top",
            "direction": "horizontal",
            "title": "Region:",
            "symbolType": "square",
            "symbolSize": 120,
            "offset": 6
          }
        },
        "tooltip": [
          {
            "field": "site_name",
            "title": "Beach"
          },
          {
            "field": "region",
            "title": "Region"
          },
          {
            "field": "avg_enterococci",
            "title": "Avg enterococci",
            "format": ".1f"
          },
          {
            "field": "poor_pct",
            "title": "% Poor",
            "format": ".1f"
          },
          {
            "field": "samples",
            "title": "Samples"
          }
        ]
      }
