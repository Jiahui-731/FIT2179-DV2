{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Yesterday's Rain Predicts Today's Bacteria",
    "subtitle": [
      "Each dot is one sample, 2020-2025.",
      "After heavy rain, bacteria climb fast."
    ],
    "anchor": "start",
    "fontSize": 18,
    "font": "Playfair Display, Georgia, serif",
    "subtitleFontSize": 14,
    "subtitleColor": "#6a6a6a",
    "subtitleFont": "Inter, sans-serif",
    "offset": 12
  },
  "width": 720,
  "height": 420,
  "background": "transparent",
  "autosize": {
    "type": "fit-x",
    "contains": "padding"
  },
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFont": "Inter",
      "titleFont": "Inter",
      "labelFontSize": 11,
      "titleFontSize": 12,
      "titleColor": "#3a3a3a",
      "gridColor": "#eee5d0",
      "domainColor": "#bbb",
      "tickColor": "#bbb"
    },
    "legend": {
      "labelFont": "Inter",
      "titleFont": "Inter",
      "labelFontSize": 11
    }
  },
  "data": {
    "url": "data/master.csv",
    "format": {
      "parse": {
        "rainfall_yesterday": "number",
        "enterococci": "number"
      }
    }
  },
  "transform": [
    {
      "filter": "datum.sample_type === 'Routine' && datum.rainfall_yesterday != null"
    }
  ],
  "layer": [
    {
      "description": "Heavy-rain danger zone background",
      "data": {
        "values": [
          {
            "x_start": 20,
            "x_end": 40,
            "y_start": 0,
            "y_end": 1000
          }
        ]
      },
      "mark": {
        "type": "rect",
        "fill": "#c73e3e",
        "opacity": 0.06
      },
      "encoding": {
        "x": {
          "field": "x_start",
          "type": "quantitative"
        },
        "x2": {
          "field": "x_end"
        },
        "y": {
          "field": "y_start",
          "type": "quantitative"
        },
        "y2": {
          "field": "y_end"
        }
      }
    },
    {
      "description": "Scatter — every sample",
      "transform": [
        {
          "filter": "datum.enterococci <= 1000"
        }
      ],
      "mark": {
        "type": "circle",
        "size": 22,
        "opacity": 0.22
      },
      "encoding": {
        "x": {
          "field": "rainfall_yesterday",
          "type": "quantitative",
          "title": "Rainfall the day before sampling (mm)",
          "scale": {
            "domain": [
              0,
              40
            ]
          },
          "axis": {
            "grid": true
          }
        },
        "y": {
          "field": "enterococci",
          "type": "quantitative",
          "title": "Enterococci (orgs / 100mL)",
          "scale": {
            "domain": [
              0,
              1000
            ]
          },
          "axis": {
            "grid": true
          }
        },
        "color": {
          "field": "safety",
          "type": "nominal",
          "title": "EPA rating",
          "scale": {
            "domain": [
              "Good",
              "Caution",
              "Poor"
            ],
            "range": [
              "#3a7ca5",
              "#d4a23a",
              "#c73e3e"
            ]
          },
          "legend": {
            "orient": "top-right"
          }
        },
        "tooltip": [
          {
            "field": "site_name",
            "title": "Beach"
          },
          {
            "field": "date",
            "title": "Date"
          },
          {
            "field": "rainfall_yesterday",
            "title": "Rain yesterday (mm)",
            "format": ".1f"
          },
          {
            "field": "enterococci",
            "title": "Enterococci"
          },
          {
            "field": "safety",
            "title": "Rating"
          }
        ]
      }
    },
    {
      "description": "Trend line — linear regression",
      "transform": [
        {
          "regression": "enterococci",
          "on": "rainfall_yesterday",
          "extent": [
            0,
            40
          ]
        }
      ],
      "mark": {
        "type": "line",
        "color": "#1e4a6b",
        "strokeWidth": 3,
        "strokeDash": [
          5,
          4
        ]
      },
      "encoding": {
        "x": {
          "field": "rainfall_yesterday",
          "type": "quantitative"
        },
        "y": {
          "field": "enterococci",
          "type": "quantitative",
          "scale": {
            "domain": [
              0,
              1000
            ]
          }
        }
      }
    },
    {
      "description": "EPA Poor threshold reference",
      "data": {
        "values": [
          {
            "y": 200
          }
        ]
      },
      "mark": {
        "type": "rule",
        "color": "#888",
        "strokeDash": [
          3,
          3
        ],
        "strokeWidth": 0.8
      },
      "encoding": {
        "y": {
          "field": "y",
          "type": "quantitative"
        }
      }
    },
    {
      "description": "Threshold label",
      "data": {
        "values": [
          {
            "x": 1,
            "y": 200,
            "label": "EPA Poor threshold (200)"
          }
        ]
      },
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "bottom",
        "dy": -3,
        "font": "Inter",
        "fontSize": 10,
        "fontStyle": "italic",
        "color": "#666"
      },
      "encoding": {
        "x": {
          "field": "x",
          "type": "quantitative"
        },
        "y": {
          "field": "y",
          "type": "quantitative"
        },
        "text": {
          "field": "label"
        }
      }
    },
    {
      "description": "Danger-zone callout",
      "data": {
        "values": [
          {
            "x": 30,
            "y": 880,
            "label": "Danger zone — heavy rain"
          }
        ]
      },
      "mark": {
        "type": "text",
        "align": "center",
        "baseline": "middle",
        "font": "Inter",
        "fontSize": 12,
        "fontWeight": 600,
        "color": "#c73e3e"
      },
      "encoding": {
        "x": {
          "field": "x",
          "type": "quantitative"
        },
        "y": {
          "field": "y",
          "type": "quantitative"
        },
        "text": {
          "field": "label"
        }
      }
    },
    {
      "description": "Slope callout above trend line near right end",
      "data": {
        "values": [
          {
            "x": 38,
            "y": 410,
            "label": "+5.4 enterococci / mm rain"
          }
        ]
      },
      "mark": {
        "type": "text",
        "align": "right",
        "baseline": "bottom",
        "dy": -6,
        "font": "Inter",
        "fontSize": 11,
        "fontWeight": 700,
        "color": "#1e4a6b"
      },
      "encoding": {
        "x": {
          "field": "x",
          "type": "quantitative"
        },
        "y": {
          "field": "y",
          "type": "quantitative"
        },
        "text": {
          "field": "label"
        }
      }
    }
  ]
}
