      "description": "Top-3 worst inline labels (>=350) — cream halo",
      "data": {
        "url": "data/beach_summary.csv",
        "format": {
          "parse": {
            "latitude": "number",
            "longitude": "number",
            "avg_enterococci": "number"
          }
        }
