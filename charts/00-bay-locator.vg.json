{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Three Beaches Above 350, Two Below 20",
    "subtitle": [
      "Frankston Coast Guard averages 34× Portsea.",
      "Circle size shows long-term mean bacteria, 2020-2025."
    ],
    "anchor": "start",
    "fontSize": 18,
    "font": "Playfair Display, Georgia, serif",
    "subtitleFontSize": 14,
    "subtitleColor": "#6a6a6a",
    "subtitleFont": "Inter, sans-serif",
    "offset": 14
  },
  "width": 760,
  "height": 650,
  "background": "transparent",
  "padding": {
    "top": 8,
    "left": 8,
    "right": 8,
    "bottom": 8
  },
  "projection": {
    "type": "mercator",
    "center": [
      144.79,
      -38.12
    ],
    "scale": 37000,
    "translate": [
      380,
      325
    ]
  },
  "config": {
    "view": {
      "stroke": null
    },
    "legend": {
      "labelFont": "Inter",
      "titleFont": "Inter",
      "labelFontSize": 11,
      "titleFontSize": 11,
      "labelColor": "#3a3a3a",
      "titleColor": "#3a3a3a"
    }
  },
  "resolve": {
    "scale": {
      "size": "independent",
      "color": "independent"
    }
  },
  "layer": [
    {
      "description": "Tertiary roads — palest cool-grey (outer-suburb + rural connector roads; fills the western/north-western rural areas)",
