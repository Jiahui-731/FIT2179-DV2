        {
          "calculate": "datum.site_name == 'Frankston Coast Guard' ? 'Frankston CG · 439' : datum.site_name == 'Carrum Surf Life Saving Club' ? 'Carrum SLC · 359' : datum.site_name == 'Port Melbourne' ? 'Port Melbourne · 368' : datum.site_name",
