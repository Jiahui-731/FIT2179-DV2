        "url": "data/osm_tertiary.geojson",
        "format": {
          "type": "json",
          "property": "features"
        }
      },
      "mark": {
        "type": "geoshape",
        "filled": false,
        "stroke": "#e8ebee",
        "strokeWidth": 0.4,
        "opacity": 0.85,
        "clip": true
      }
    },
    {
      "description": "Secondary roads — light cool-grey, single thin stroke (suburb-grade thoroughfares, gives the city its grid texture)",
