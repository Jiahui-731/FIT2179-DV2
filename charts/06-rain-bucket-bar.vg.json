{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Rain Tilts the Whole Distribution",
    "subtitle": [
      "Sample ratings split by yesterday's rain bucket.",
      "Heavy rain nearly doubles the failure rate."
    ],
    "anchor": "start",
    "fontSize": 18,
    "font": "Playfair Display, Georgia, serif",
    "subtitleFontSize": 14,
    "subtitleColor": "#6a6a6a",
    "subtitleFont": "Inter, sans-serif",
    "offset": 12
  },
  "width": 580,
  "height": 320,
  "background": "transparent",
  "autosize": {
    "type": "fit-x",
    "contains": "padding"
  },
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFont": "Inter",
      "titleFont": "Inter",
      "labelFontSize": 12,
      "titleFontSize": 12,
      "labelColor": "#3a3a3a",
      "domainColor": "#bbb",
      "tickColor": "#bbb",
      "gridColor": "#e8e2d0"
    },
    "legend": {
      "labelFont": "Inter",
      "titleFont": "Inter",
      "labelFontSize": 11,
      "titleFontSize": 11
    }
  },
  "data": {
    "url": "data/rainfall_breakdown.csv"
  },
  "transform": [
    {
      "calculate": "indexof(['Dry (0mm)','Light (<5mm)','Moderate (5-20mm)','Heavy (20mm+)'], datum.rain_yesterday_bucket)",
      "as": "bucket_idx"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "bar",
        "height": {
          "band": 0.62
        },
        "stroke": "#ffffff",
        "strokeWidth": 1.5
      },
      "encoding": {
        "y": {
          "field": "rain_yesterday_bucket",
          "type": "ordinal",
          "title": null,
          "scale": {
            "domain": [
              "Dry (0mm)",
              "Light (<5mm)",
              "Moderate (5-20mm)",
              "Heavy (20mm+)"
            ]
          },
          "axis": {
            "labelPadding": 12,
            "labelFontSize": 12,
            "labelFontWeight": 500
          }
        },
        "x": {
          "field": "pct",
          "type": "quantitative",
          "stack": "zero",
          "title": "Share of routine samples (%)",
          "axis": {
            "grid": true,
            "format": ".0f",
            "values": [
              0,
              25,
              50,
              75,
              100
            ]
          }
        },
        "color": {
          "field": "safety",
          "type": "nominal",
          "title": null,
          "scale": {
            "domain": [
              "Good",
              "Caution",
              "Poor"
            ],
            "range": [
              "#3a7ca5",
              "#d4a23a",
              "#c73e3e"
            ]
          },
          "legend": {
            "orient": "top",
            "direction": "horizontal",
            "symbolType": "square",
            "symbolSize": 140
          }
        },
        "order": {
          "field": "safety_idx",
          "type": "ordinal"
        },
        "tooltip": [
          {
            "field": "rain_yesterday_bucket",
            "title": "Bucket"
          },
          {
            "field": "safety",
            "title": "Rating"
          },
          {
            "field": "pct",
            "title": "Share %",
            "format": ".1f"
          },
          {
            "field": "n",
            "title": "Samples"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "center",
        "baseline": "middle",
        "font": "Inter",
        "fontSize": 12,
        "fontWeight": 700
      },
      "encoding": {
        "y": {
          "field": "rain_yesterday_bucket",
          "type": "ordinal",
          "scale": {
            "domain": [
              "Dry (0mm)",
              "Light (<5mm)",
              "Moderate (5-20mm)",
              "Heavy (20mm+)"
            ]
          }
        },
        "x": {
          "field": "pct",
          "type": "quantitative",
          "stack": "zero",
          "bandPosition": 0.5
        },
        "text": {
          "field": "pct",
          "format": ".0f",
          "type": "quantitative"
        },
        "order": {
          "field": "safety_idx",
          "type": "ordinal"
        },
        "color": {
          "condition": {
            "test": "datum.safety == 'Caution'",
            "value": "#3a3a3a"
          },
          "value": "white"
        },
        "opacity": {
          "condition": {
            "test": "datum.pct < 5",
            "value": 0
          },
          "value": 1
        }
      }
    },
    {
      "description": "Heavy-rain Poor callout — placed inside the Caution segment of Heavy row",
      "data": {
        "values": [
          {
            "label": "1.8× the dry-day Poor rate",
            "x": 92,
            "bucket": "Heavy (20mm+)"
          }
        ]
      },
      "mark": {
        "type": "text",
        "align": "right",
        "baseline": "middle",
        "dx": -8,
        "dy": -22,
        "font": "Inter",
        "fontSize": 10.5,
        "fontStyle": "italic",
        "color": "#c73e3e",
        "fontWeight": 700
      },
      "encoding": {
        "y": {
          "field": "bucket",
          "type": "ordinal",
          "scale": {
            "domain": [
              "Dry (0mm)",
              "Light (<5mm)",
              "Moderate (5-20mm)",
              "Heavy (20mm+)"
            ]
          }
        },
        "x": {
          "field": "x",
          "type": "quantitative"
        },
        "text": {
          "field": "label"
        }
      }
    }
  ]
}
